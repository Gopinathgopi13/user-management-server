{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../../",
    "baseUrl": "src",
    "paths": {
      "@config": ["config/index"],
      "@config/*": ["config/*"],
      "@middlewares/*": ["middlewares/*"],
      "@routes/*": ["routes/*"],
      "@utils/*": ["utils/*"],
      "@shared/logger": ["../../../shared/logger/index"]
    }
  },
  "include": ["src", "../../shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
